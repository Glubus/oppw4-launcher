{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OPPW4 Launcher",
  "version": "0.1.0",
  "identifier": "am.prism.oppw4.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OPPW4 Launcher",
        "width": 1120,
        "height": 720,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}

